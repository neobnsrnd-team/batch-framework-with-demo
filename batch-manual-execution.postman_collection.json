    {
      "name": "04. BATCH_EXEC_NPE",
      "description": "executeBatch() 미처리 예외 (NullPointerException) 시나리오",
      "item": [

        {
          "name": "04-01. NPE 발생 → FAILED_EXEC (NullPointerException)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_EXEC_NPE/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_EXEC_NPE","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": false,\n  \"params\": {}\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 FAILED_EXEC', () => pm.expect(body.resRtCode).to.eql('FAILED_EXEC'));",
                  "pm.test('errorCode=NullPointerException (프레임워크 자동 포착)', () => {",
                  "  pm.expect(body.errorCode).to.eql('NullPointerException');",
