{
  "info": {
    "name": "HanaBank NBC MIS - 배치 수동 실행 API",
    "_postman_id": "hanabank-batch-manual-v1",
    "description": "배치 수동 실행 REST API 테스트 컬렉션\n\n## 인증\nBasic Auth: batchadmin / batchpass\n\n## 엔드포인트\nPOST /api/batch/{batchAppId}/run\n\n## 데모 배치 목록\n| BATCH_APP_ID | 시나리오 |\n|---|---|\n| BATCH_DAILY_REPORT | 정상 수행 (100건) |\n| BATCH_DATA_SYNC | 정상 수행 + 선행 배치 의존 (500건) |\n| BATCH_INIT_FAIL | init() 실패 (파라미터 누락/무효) |\n| BATCH_EXEC_NPE | executeBatch() NPE 미처리 예외 |\n| BATCH_EXEC_BIZ_FAIL | executeBatch() 비즈니스 예외 |\n| BATCH_PARTIAL_FAIL | 부분 실패 (단건 오류 계속 진행) |\n| BATCH_SLOW_PROCESS | 대용량 처리 (처리 시간 모니터링) |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",   "value": "http://localhost:8080", "type": "string" },
    { "key": "username",  "value": "batchadmin",            "type": "string" },
    { "key": "password",  "value": "batchpass",             "type": "string" },
    { "key": "today",     "value": "20260319",              "type": "string", "description": "오늘 날짜 YYYYMMDD" },
    { "key": "yesterday", "value": "20260318",              "type": "string", "description": "어제 날짜 YYYYMMDD" }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "item": [

    {
      "name": "01. BATCH_DAILY_REPORT",
      "description": "일일 리포트 배치 — 정상 수행 시나리오",
      "item": [

        {
          "name": "01-01. 기본 실행 (파라미터 없음)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": false,\n  \"params\": {}\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 SUCCESS', () => pm.expect(body.resRtCode).to.eql('SUCCESS'));",
                  "pm.test('성공건수 > 0', () => pm.expect(body.successCount).to.be.above(0));",
                  "pm.test('실패건수 = 0', () => pm.expect(body.failCount).to.eql(0));",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        },

        {
          "name": "01-02. 커스텀 파라미터 (reportType=WEEKLY, threshold=50)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": false,\n  \"params\": {\n    \"reportType\": \"WEEKLY\",\n    \"threshold\": \"50\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 SUCCESS', () => pm.expect(body.resRtCode).to.eql('SUCCESS'));",
                  "pm.test('baseBatchDate 확인', () => pm.expect(body.baseBatchDate).to.eql(pm.collectionVariables.get('today')));",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        },

        {
          "name": "01-03. 어제 날짜 기준 실행 (baseBatchDate=yesterday)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{yesterday}}\",\n  \"forceRerun\": false,\n  \"params\": {\n    \"reportType\": \"DAILY\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 SUCCESS', () => pm.expect(body.resRtCode).to.eql('SUCCESS'));",
                  "pm.test('baseBatchDate=어제', () => pm.expect(body.baseBatchDate).to.eql(pm.collectionVariables.get('yesterday')));",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        },

        {
          "name": "01-04. 이미 성공 이력 있을 때 → 409 Conflict",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": false,\n  \"params\": {}\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": ["// 01-01을 먼저 실행하여 SUCCESS 이력을 만든 후 이 요청을 실행하세요"] }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 409 Conflict', () => pm.response.to.have.status(409));",
                  "pm.test('이미 성공 이력 존재 오류', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(JSON.stringify(body)).to.include('forceRerun');",
                  "});",
                  "console.log('응답:', pm.response.text());"
                ]
              }
            }
          ]
        },

        {
          "name": "01-05. 강제 재실행 (forceRerun=true) → SUCCESS + canceledCount≥1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": true,\n  \"params\": {\n    \"reportType\": \"DAILY\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": ["// 01-01 실행 후 이 요청을 실행하면 기존 SUCCESS → CANCELED 처리 후 재실행됩니다"] }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 SUCCESS', () => pm.expect(body.resRtCode).to.eql('SUCCESS'));",
                  "pm.test('forceRerun=true 확인', () => pm.expect(body.forceRerun).to.be.true);",
                  "pm.test('canceledCount ≥ 1', () => pm.expect(body.canceledCount).to.be.at.least(1));",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        },

        {
          "name": "01-06. threshold=0 → 실패 건수 0 이상이면 FAILED_EXEC",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": true,\n  \"params\": {\n    \"reportType\": \"DAILY\",\n    \"threshold\": \"0\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "// threshold=0이면 모든 처리가 성공(실패=0)이므로 SUCCESS",
                  "pm.test('결과 SUCCESS (threshold 초과 없음)', () => pm.expect(body.resRtCode).to.eql('SUCCESS'));",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        },

        {
          "name": "01-07. threshold 파라미터 형식 오류 → FAILED_INIT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url":    { "raw": "{{baseUrl}}/api/batch/BATCH_DAILY_REPORT/run", "host": ["{{baseUrl}}"], "path": ["api","batch","BATCH_DAILY_REPORT","run"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseBatchDate\": \"{{today}}\",\n  \"forceRerun\": true,\n  \"params\": {\n    \"threshold\": \"NOT_A_NUMBER\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('HTTP 200 (실행은 됐지만 init 실패)', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('결과 FAILED_INIT', () => pm.expect(body.resRtCode).to.eql('FAILED_INIT'));",
                  "pm.test('errorCode 존재', () => pm.expect(body.errorCode).to.not.be.null);",
                  "pm.test('errorReason 존재', () => pm.expect(body.errorReason).to.not.be.null);",
                  "console.log('결과:', JSON.stringify(body, null, 2));"
                ]
              }
            }
          ]
        }
      ]
    },

